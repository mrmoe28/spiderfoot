<%include file="HEADER.tmpl"/>
<script src="${docroot}/static/js/spiderfoot.newscan.js"></script>

<div style='padding-top: 10px'>
<form class="form" action='${docroot}/startscan' method='POST'>

  <p class="sf-page-lead">Choose what you want to do, then enter your target.</p>

  <!-- ── Mode cards ───────────────────────────────────────── -->
  <div class="sf-section-label">What do you want to do?</div>
  <div class="row" id="sf-mode-cards">

    <div class="col-xs-12 col-sm-6 col-md-3 sf-card-col">
      <div class="panel panel-default sf-mode-card"
           data-mode="Investigate"
           data-placeholder="Domain, email, IP, username, or name in quotes">
        <div class="panel-body text-center">
          <div class="sf-card-icon"><i class="glyphicon glyphicon-search"></i></div>
          <h4 class="sf-card-title">Investigate</h4>
          <p class="text-muted sf-card-desc">Look up a person, domain, email, or username</p>
        </div>
      </div>
    </div>

    <div class="col-xs-12 col-sm-6 col-md-3 sf-card-col">
      <div class="panel panel-default sf-mode-card"
           data-mode="Footprint"
           data-placeholder="Your domain, e.g. mycompany.com">
        <div class="panel-body text-center">
          <div class="sf-card-icon"><i class="glyphicon glyphicon-eye-open"></i></div>
          <h4 class="sf-card-title">Check My Exposure</h4>
          <p class="text-muted sf-card-desc">Map what your domain or company leaks publicly</p>
        </div>
      </div>
    </div>

    <div class="col-xs-12 col-sm-6 col-md-3 sf-card-col">
      <div class="panel panel-default sf-mode-card"
           data-mode="Passive"
           data-placeholder="Suspicious email address or domain">
        <div class="panel-body text-center">
          <div class="sf-card-icon"><i class="glyphicon glyphicon-ok-sign"></i></div>
          <h4 class="sf-card-title">Verify a Sender</h4>
          <p class="text-muted sf-card-desc">Is this email, link, or domain legitimate?</p>
        </div>
      </div>
    </div>

    <div class="col-xs-12 col-sm-6 col-md-3 sf-card-col">
      <div class="panel panel-default sf-mode-card"
           data-mode="all"
           data-placeholder="Any domain, email, IP, username, or name in quotes">
        <div class="panel-body text-center">
          <div class="sf-card-icon"><i class="glyphicon glyphicon-flash"></i></div>
          <h4 class="sf-card-title">Full Deep Scan</h4>
          <p class="text-muted sf-card-desc">Everything — slow but the most thorough</p>
        </div>
      </div>
    </div>

  </div><!-- /.row#sf-mode-cards -->

  <!-- ── Target + run — revealed after card pick ──────────── -->
  <div id="sf-target-section" style="display:none">
    <div class="sf-section-label">Enter your target</div>
    <div class="row">
      <div class="col-xs-12 col-sm-6">
        <div class="form-group">
          <input class="form-control input-lg" type="text" id="scantarget" name="scantarget"
                 value="${scantarget}" placeholder="Domain, email, IP, username...">
          <span class="help-block" id="sf-target-hint"></span>
        </div>
      </div>
      <div class="col-xs-12 col-sm-4">
        <div class="form-group">
          <input class="form-control input-lg" type="text" id="scanname" name="scanname"
                 value="${scanname}" placeholder="Scan name (optional)">
        </div>
      </div>
      <div class="col-xs-12 col-sm-2">
        <button id="btn-run-scan" class="btn btn-danger btn-lg btn-block">
          <i class="glyphicon glyphicon-play"></i> Scan
        </button>
      </div>
    </div>

    <a href="#" class="sf-advanced-link" id="sf-advanced-toggle">
      <i class="glyphicon glyphicon-cog"></i>&nbsp;Advanced — choose specific modules
    </a>
  </div><!-- /#sf-target-section -->

  <!-- ── Advanced panel ───────────────────────────────────── -->
  <div id="sf-advanced-panel" style="display:none">
    <div class="control-group" style="margin-top: 10px">
      <ul class='nav nav-tabs'>
        <li id='usetab' class="active"><a href='#'>By Use Case</a></li>
        <li id='typetab'><a href='#'>By Required Data</a></li>
        <li id='moduletab'><a href='#'>By Module</a></li>
        <div class='btn-group-sm pull-right' role="group" id='selectors'>
          <button id="btn-select-all" type="button" class="btn btn-info">Select All</button>&nbsp;&nbsp;
          <button id="btn-deselect-all" type="button" class="btn btn-info">De-Select All</button>
        </div>
      </ul>

      <div class="table-responsive"><table class="table table-striped table-condensed" id="usetable">
        <tr><td style='width:50px'><input type=radio name='usecase' value='all' id="usecase_all" checked></td><td>All</td><td><b>Get anything and everything about the target.</b><br><br>All SpiderFoot modules will be enabled (slow) but every possible piece of information about the target will be obtained and analysed.</td></tr>
        <tr><td><input type=radio name='usecase' value='Footprint' id="usecase_footprint"></td><td>Footprint</td><td><b>Understand what information this target exposes to the Internet.</b><br><br>Gain an understanding about the target's network perimeter, associated identities and other information that is obtained through a lot of web crawling and search engine use.</td></tr>
        <tr><td><input type=radio name='usecase' value='Investigate' id="usecase_investigate"></td><td>Investigate</td><td><b>Best for when you suspect the target to be malicious but need more information.</b><br><br>Some basic footprinting will be performed in addition to querying of blacklists and other sources that may have information about your target's maliciousness.</td></tr>
        <tr><td><input type=radio name='usecase' value='Passive' id="usecase_passive"></td><td>Passive</td><td><b>When you don't want the target to even suspect they are being investigated.</b><br><br>As much information will be gathered without touching the target or their affiliates, therefore only modules that do not touch the target will be enabled.</td></tr>
      </table></div>

      <div class="table-responsive"><table class="table table-striped table-condensed" id="moduletable" style="display:none">
          <%
          modlist = dict()
          for item in modules:
              modlist[modules[item]['name']] = item
          %>
          % for it in sorted(modlist, key=lambda v: v.upper()):
              <% item = modlist[it] %>
              <% keylist = dict((k, v) for k, v in modules[item]['opts'].items() if not k.startswith('_')) %>
              <% keyicon = "" %>
              % if len(keylist) > 0:
                  <% apikeylist = dict((k, v) for k, v in modules[item]['opts'].items() if k.find("api_key") >= 0) %>
                  <%
                  if len(apikeylist) > 0:
                      keyicon = "&nbsp;&nbsp;<i class=\"glyphicon glyphicon-lock\" rel='tooltip' title='Needs API key'></i>"
                  %>
              % endif
              % if item != "sfp__stor_db" and item != "sfp__stor_stdout":
                  <tr><td><input type=checkbox id="module_${item}" checked></td><td>${modules[item]['name']}${keyicon}</td><td>${modules[item]['descr']}</td></tr>
              % endif
          % endfor
      </table></div>

      <div class="table-responsive"><table class="table table-striped table-condensed" id="typetable" style="display:none">
          <% count = 0 %>
          % for item in sorted(types):
              % if count % 2 == 0:
                  <tr>
              % endif
              <td><input type=checkbox id="type_${item[1]}" checked></td><td>${item[0]}</td>
              % if not count % 2 == 0:
                  </tr>
              % endif
              <% count = count + 1 %>
          % endfor
      </table></div>
    </div>
  </div><!-- /#sf-advanced-panel -->

  <input type=hidden id='modulelist' name='modulelist' value=''>
  <input type=hidden id='typelist' name='typelist' value=''>

</form>
</div>

<script type='text/javascript'>
  // ── Card selection ──────────────────────────────────────
  var modeHints = {
    'Investigate': 'e.g. suspicious-domain.com, bob@example.com, "John Smith", or jsmith99',
    'Footprint':   'e.g. mycompany.com or 203.0.113.0/24',
    'Passive':     'e.g. invoice-scam.net or noreply@phishing.com',
    'all':         'e.g. example.com, 1.2.3.4, "Jane Doe", bob@example.com'
  };

  $('.sf-mode-card').on('click', function() {
    var $card = $(this);
    var mode  = $card.data('mode');

    // Update card highlight
    $('.sf-mode-card').removeClass('sf-card-selected').closest('.panel').removeClass('panel-primary').addClass('panel-default');
    $card.addClass('sf-card-selected').closest('.panel').removeClass('panel-default').addClass('panel-primary');

    // Sync the hidden radio (for form POST and existing JS)
    $('#usecase_' + mode).prop('checked', true);

    // Update placeholder + hint
    $('#scantarget').attr('placeholder', $card.data('placeholder'));
    $('#sf-target-hint').text(modeHints[mode] || '');

    // Reveal target section
    $('#sf-target-section').slideDown(200);
    $('#scantarget').focus();
  });

  // ── Advanced toggle ─────────────────────────────────────
  $('#sf-advanced-toggle').on('click', function(e) {
    e.preventDefault();
    var $panel = $('#sf-advanced-panel');
    var $icon  = $(this).find('.glyphicon');
    if ($panel.is(':hidden')) {
      $panel.slideDown(200);
      $icon.removeClass('glyphicon-cog').addClass('glyphicon-remove');
      switchTab('use');
    } else {
      $panel.slideUp(200);
      $icon.removeClass('glyphicon-remove').addClass('glyphicon-cog');
    }
  });

  // ── Tab wiring (usetab clicks sync the card selection too) ─
  $("#usetab").off('click').on('click', function() { switchTab("use"); });
  $("#typetab").off('click').on('click', function() { switchTab("type"); });
  $("#moduletab").off('click').on('click', function() { switchTab("module"); });

  // ── Restore state when re-running with selectedmods ─────
  % if "${selectedmods}" != "":
    $('#sf-advanced-panel').show();
    switchTab("module");
    $("input[id^=module_]").each(function(id, obj) {
      if ("${selectedmods}".indexOf(obj.id.replace("module_", "")) >= 0) {
        $("#" + obj.id).prop("checked", true);
      } else {
        $("#" + obj.id).prop("checked", false);
      }
    });
    $('#sf-target-section').show();
  % endif
</script>

<%include file="FOOTER.tmpl"/>
