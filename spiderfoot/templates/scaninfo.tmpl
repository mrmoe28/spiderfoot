            'CLOUD_STORAGE_BUCKET': 'BotStop found a cloud storage bucket associated with my domain.\n\nBucket found: [paste from scan]\n\nPlease help me:\n1. Verify whether this bucket is publicly accessible\n2. If public, restrict it to private access immediately\n3. Review what files it contains for any sensitive data\n4. Audit all buckets in my cloud account for public access\n5. Enable bucket versioning and access logging\n\nCloud provider: [AWS S3 / Google Cloud Storage / Azure Blob]',

            'DOMAIN_WHOIS': 'BotStop found that my domain WHOIS registration data is publicly visible.\n\nPlease help me:\n1. Enable WHOIS privacy protection through my registrar (hides my name, address, phone, email from public lookup)\n2. Verify my registrar contact info is up-to-date and accurate (required for domain ownership)\n3. Check that my domain is locked to prevent unauthorized transfers\n\nMy registrar: [GoDaddy / Namecheap / Google Domains / Cloudflare / etc.]',

            'AFFILIATE_DOMAIN_WHOIS': 'BotStop found that WHOIS data for a domain affiliated with mine is publicly visible.\n\nAffiliated domain: [from scan]\n\nPlease help me:\n1. Verify if I own or control this affiliated domain\n2. Enable WHOIS privacy on it if I do\n3. If I don\'t own it, check if it could be used to impersonate my brand\n\nMy registrar: [your registrar]',

            'WEBSERVER_HTTPHEADERS': 'BotStop found HTTP response headers on my web server. Some headers may reveal too much or be missing security headers.\n\nHeaders found: [from scan]\n\nPlease help me:\n1. Add missing security headers: Content-Security-Policy, X-Frame-Options, X-Content-Type-Options, Strict-Transport-Security, Referrer-Policy\n2. Remove or mask headers that reveal server version info (Server, X-Powered-By)\n3. Add Permissions-Policy to restrict browser features\n4. Test with securityheaders.com\n\nMy web server: [nginx / Apache / Caddy / IIS]',

            'HTTP_CODE': 'BotStop found HTTP status codes from my server. Non-200 codes may indicate broken pages, access issues, or information leaks.\n\nStatus codes found: [from scan]\n\nPlease help me:\n1. Review any 403/404 responses — are they expected or broken links?\n2. Ensure 500 errors don\'t expose stack traces or debug info\n3. Check that redirect chains (301/302) are minimal and correct\n4. Set up proper custom error pages that don\'t leak server info\n\nMy web server/framework: [your stack]',

            'AFFILIATE_INTERNET_NAME': 'BotStop found domain names or hostnames affiliated with my main domain — partner sites, CDNs, or shared infrastructure.\n\nAffiliated hostnames: [from scan]\n\nPlease help me:\n1. Verify each affiliated domain is intentional and still in use\n2. Check that abandoned subdomains are removed from DNS (dangling DNS = hijacking risk)\n3. Ensure affiliated services don\'t have weaker security than my main site\n\nMy DNS provider: [Cloudflare / Route53 / GoDaddy / etc.]',

            'AFFILIATE_IPADDR': 'BotStop found IP addresses associated with services affiliated with my domain.\n\nAffiliated IPs: [from scan]\n\nPlease help me:\n1. Verify these IPs are intentional (CDN, load balancer, third-party service)\n2. Check that firewall rules on these IPs are as strict as my main server\n3. Ensure none of these IPs are running outdated or unpatched services\n\nMy infrastructure: [AWS / GCP / DigitalOcean / Cloudflare / etc.]',

            'EMAILADDR': 'BotStop found email addresses associated with my domain in public sources.\n\nEmails found: [from scan]\n\nPlease help me:\n1. Assess if these emails being public creates phishing or spam risk\n2. Consider using role-based emails (info@, support@) instead of personal addresses in public places\n3. Check each email address in HaveIBeenPwned for breach exposure\n4. Set up DMARC so spammers can\'t spoof these addresses\n\nMy email provider: [Gmail Workspace / Microsoft 365 / etc.]',

            'CO_HOSTED_SITE': 'BotStop found other websites hosted on the same server as my site.\n\nCo-hosted sites: [from scan]\n\nPlease help me:\n1. Understand the risk: if a co-hosted site is compromised, attackers may pivot to mine\n2. Check if my hosting is on shared hosting (higher risk) vs. dedicated/VPS (lower risk)\n3. If on shared hosting, consider moving to VPS or cloud hosting with isolated environments\n4. Ensure my site has proper file permission isolation (no world-readable config files)\n\nMy hosting: [shared / VPS / dedicated / cloud]',

            'SOCIAL_MEDIA': 'BotStop found social media profiles linked to my domain or organization.\n\nProfiles found: [from scan]\n\nPlease help me:\n1. Verify these accounts are official and haven\'t been hijacked\n2. Enable 2FA on all social media accounts\n3. Check for impostor accounts using my brand name\n4. Review what personal or sensitive info is visible on these profiles\n\nPlatforms: [Twitter/X, LinkedIn, Facebook, Instagram, etc.]',

            'PHONE_NUMBER': 'BotStop found phone numbers associated with my domain in public data.\n\nPhone numbers found: [from scan]\n\nPlease help me:\n1. Verify these are business numbers (not personal) that should be public\n2. Check if these numbers could be used for vishing (voice phishing) attacks on my staff\n3. If numbers shouldn\'t be public, remove them from the sources where they appear\n4. Consider using a dedicated business phone system that masks personal numbers'
        };

        function showTypeInfo(typeId, typeName, total, unique) {
            var desc = eventTypeHelp[typeId] || 'This data type was collected during the scan.';
            var threats = eventTypeThreats[typeId];
            var fix = eventTypeFix[typeId];

            document.getElementById('info-panel-title').textContent = typeName;

            var countsHtml = '';
            if (total !== undefined && total !== null) {
                countsHtml = '<span class="badge alert-info">' + total + ' total</span> ' +
                             '<span class="badge alert-success">' + unique + ' unique</span>';
            }
            document.getElementById('info-panel-counts').innerHTML = countsHtml;
            document.getElementById('info-panel-desc').textContent = desc;

            var threatsSection = document.getElementById('info-panel-threats-section');
            var threatsList = document.getElementById('info-panel-threats');
            if (threats && threats.length > 0) {
                threatsList.innerHTML = threats.map(function(t) { return '<li>' + t + '</li>'; }).join('');
                threatsSection.style.display = '';
            } else {
                threatsSection.style.display = 'none';
            }

            var fixSection = document.getElementById('info-panel-fix-section');
            var fixPromptEl = document.getElementById('info-panel-fix-prompt');
            if (fix) {
                fixPromptEl.textContent = fix;
                fixSection.style.display = '';
            } else {
                fixSection.style.display = 'none';
            }

            document.getElementById('type-info-panel').classList.add('panel-open');
        }

        function copyFixPrompt() {
            var text = document.getElementById('info-panel-fix-prompt').textContent;
            var btn = document.getElementById('info-panel-copy-btn');
            function showCopied() {
                btn.innerHTML = '<i class="glyphicon glyphicon-ok"></i> Copied!';
                setTimeout(function() {
                    btn.innerHTML = '<i class="glyphicon glyphicon-copy"></i> Copy prompt';
                }, 2000);
            }
            if (navigator.clipboard) {
                navigator.clipboard.writeText(text).then(showCopied);
            } else {
                var ta = document.createElement('textarea');
                ta.value = text;
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
                showCopied();
            }
        }

        function closeInfoPanel() {
            document.getElementById('type-info-panel').classList.remove('panel-open');
        }
        var lastSearchType = "ALL";
        var lastSearchQuery = "";
        var dataloaders = [];
        var sharedSigma = "";
        var loadersrunning = false;
        var refresh = function() { browseEventList("${id}"); }
        $('#searchvalue').popover({ 'trigger': 'focus', 'placement': 'bottom'});
        $('#searchvalue').keyup(function(event) {
            if (event.keyCode == 13) {
                $('#searchbutton').click();
            }
        });

        function switchSelectAll() {
            if (!$("#checkall")[0].checked) {
                $("input[id*=cb_]").prop('checked', false);
            } else {
                $("input[id*=cb_]").prop('checked', true);
            }
        }

        function getSelected() {
            ids = [];
            $("input[id*=cb_]").each(function(i, obj) {
                if (obj.checked) {
                    ids[ids.length] = obj.id.replace("cb_", "");
                }
            });

            return ids;
        }

        function setFp(flag) {
            sel = getSelected();
            if (sel.length == 0) {
                alertify.error("You need to select at least one record.");
                return false;
            }
            data = JSON.stringify(sel);
            $("#loader").show();
            sf.fetchData('${docroot}/resultsetfp', {'id': '${id}', 'fp': flag, 'resultids': data }, function(ret) {
                $("#loader").hide();
                if (ret[0] == "SUCCESS") {
                    refresh();
                    return;
                }
                if (ret[0] == "WARNING") {
                    alertify.error(ret[1]);
                    return;
                }
                if (ret[0] == "ERROR") {
                    alertify.error("There was an error setting false positives because: " + ret[1] + "<br/>If you believe this to be an error, please log out and log back in, and if the problem repeats, report this as a bug.");
                }
            });
        }

        function navTo(target) {
            var targets = [ "btn-browse", "btn-info", "btn-log",
                "btn-export", "btn-download-logs", "btn-viz",
                "btn-status", "btn-graph", "btn-correlations", "btn-report" ]
            for (var i = 0; i < targets.length; i++) {
                if (targets[i] == target) {
                    $("#" + targets[i]).addClass("active");
                } else {
                    $("#" + targets[i]).removeClass("active");
                }
            }

            $("#breadcrumbs").remove();
            $("#customtabview").hide();
            $("#customvizview").hide();
            $("#modifyactions").hide();
            currentSection = target
            dataloaders = []
        }

        function searchDirector(instanceId) {
            qry = $("#searchvalue").val();
            if (currentType == "ALL") {
                searchResults(instanceId, qry);
            } else {
                searchResults(instanceId, qry, currentType);
            }
        }

        function searchResults(instanceId, query, typeName) {
            // Remove pre-existing tables if they exist
            $("#scansummary-content").remove();
            $("#scanlogs-content").remove();
            navTo("btn-search");
            $("#modifyactions").hide();
            $("#loader").show();
            $("#btn-export").show();
            $("#btn-download-logs").hide();
            $("#btn-refresh").show();
            $("#btn-search").show();
            $("#scanreminder").hide();
            refresh = function() { searchResults(instanceId, query, typeName); }
            sf.search(instanceId, query, typeName, function(data) {
                            lastSearchType = typeName;
                            lastSearchQuery = query;
                            var crumbs = " <ul class='breadcrumb' id='breadcrumbs'> <li><a class='link' onClick='browseEventList(\"" + instanceId + "\");'>Browse</a>";
                            crumbs += " <span class='divider'></span></li>";
                            if (typeName != null) {
                                crumbs += " <li><a class='link' onClick=";
                                crumbs += "'browseEventData(\"" + instanceId + "\",\"" + currentTypeName + "\",\"" + typeName + "\",\"full\");'>";
                                crumbs += unescape(currentTypeName) + "</a><span class='divider'></span></li>";
                            }
                            crumbs += "<li>Search results";
                            crumbs += " (" + data.length + " records)</li></ul>";

                            if (data.length == 0) {
                                var table = "<div id='scansummary-content'>&nbsp;&nbsp;No results found. Try broadening your search criteria.</div>";
                            } else {
                                var table = "<table id='scansummary-content' class='table table-bordered table-striped small tablesorter'><thead><tr>";
                                if (typeName == null) {
                                    table += "<th class='sorter-false'>Data Element Type</th>";
                                }
                                table += "<th>Data Element</th><th>Source Data Element</th><th>Source Module</th><th class='text-center'>Confidence</th><th>Identified</th></tr></thead><tbody>";
                                for (var i = 0; i < data.length; i++) {
                                    table += "<tr>";
                                    if (typeName == null) {
                                        table += "<td><pre class='table-border-bg-inherit'>" + data[i][8] + "</pre></td>";
                                    }
                                    table += "<td><pre class='table-border-bg-inherit'>";
                                    table += sf.replace_sfurltag(data[i][1]);
                                    // for debug
                                    table += "</pre></td><td><pre class='table-border-bg-inherit'>";
                                    table += sf.replace_sfurltag(data[i][2]);
                                    table += "</pre></td><td><pre class='table-border-bg-inherit'>" + data[i][3];
                                    table += "</pre></td>";
                                    var conf1 = data[i][4] || 0;
                                    var confCls1 = conf1 >= 80 ? 'label-success' : conf1 >= 60 ? 'label-warning' : conf1 >= 40 ? 'label-default' : 'label-danger';
                                    table += "<td class='text-center'><span class='label " + confCls1 + "'>" + conf1 + "%</span></td>";
                                    table += "<td><pre class='table-border-bg-inherit'>" + data[i][0];
                                    table += "</pre></td>";
                                    table += "</tr>";
                                }
                                table += "</tbody></table>"
                            }
                            $("#loader").fadeOut(500);
                            $("#mainbody").append(crumbs + table);
                            $("#scansummary-content").tablesorter();
            });
        }

        // Visualisation
        function graphEvents(instanceId) {
            grid = "<div id='scansummary-content'><br />"
            grid += "<div class='col-md-12 graph-container' id='graph-container'></div>"
            grid += "</div>"

            $("#scansummary-content").remove();
            $("#scanlogs-content").remove();
            $("#loader").show();
            $("#btn-export").show();
            $("#btn-download-logs").hide();
            $("#btn-refresh").show();
            $("#btn-search").hide();
            $("#btn-graph").show();
            $("#scanreminder").hide();
            refresh = function() { graphEvents(instanceId); }
            navTo("btn-graph");
            $("#customvizview").show();
            $("#mainbody").append(grid);
            $("#btn-forceatlas").removeClass("active");
            $("#btn-random").addClass("active");

            sigma.renderers.def = sigma.renderers.canvas
            sigma.parsers.json("${docroot}/scanviz?id=" + instanceId + "&gexf=0", {
                container: 'graph-container'
            }, function(s) { 
                if (s.renderers[0].nodesOnScreen.length == 0) {
                    $("#graph-container").append("<div class='alert alert-danger'>Insufficient data to produce a graph.</div>");
                    $("#loader").hide();
                    return;
                }
                sharedSigma = s;
                s.settings({
                    edgeColor: 'default',
                    defaultEdgeColor: '#aaa',
                    maxNodeSize: 5
                });
                sigma.plugins.dragNodes(s, s.renderers[0])
                s.refresh()
                $("#loader").hide();
            });
        }

        function vizUpdate(method) {
            s = sharedSigma
            if (method == "force") {
                $("#btn-forceatlas").addClass("active");
                $("#btn-random").removeClass("active");
                s.startForceAtlas2();
                s.refresh();
                setTimeout(function() { s.stopForceAtlas2() }, 5000);
            }

            if (method == "random") {
                $("#btn-forceatlas").removeClass("active");
                $("#btn-random").addClass("active");
                refresh();
            }

            if (method == "download") {
                s.renderers[0].snapshot({download: true});
            }
        }

        // Scan status
        function scanSummaryView(instanceId) {
            grid = "<div id='scansummary-content'>";

            // Plain-English status card
            grid += "<div class='panel panel-default'><div class='panel-body'>";
            grid += "<table class='table table-condensed' style='margin-bottom:0'>";
            grid += "<tbody>";
            grid += "<tr><td style='width:130px'><strong>Status</strong></td><td><span id='status'>Loading...</span></td></tr>";
            grid += "<tr><td><strong>Target</strong></td><td><span id='scan-target'>Loading...</span></td></tr>";
            grid += "<tr><td><strong>Started</strong></td><td><span id='scan-started'>Loading...</span></td></tr>";
            grid += "<tr><td><strong>Finished</strong></td><td><span id='scan-ended'>—</span></td></tr>";
            grid += "<tr><td><strong>Findings</strong></td><td><span id='tcounter'>?</span> total, <span id='ucounter'>?</span> unique, <span id='errors'>?</span> errors</td></tr>";
            grid += "<tr><td><strong>Correlations</strong></td>";
            grid += "<td>";
            grid += "<span class='badge alert-danger' id='corr-high'>?</span>&nbsp;High&nbsp;&nbsp;";
            grid += "<span class='badge alert-warning' id='corr-medium'>?</span>&nbsp;Medium&nbsp;&nbsp;";
            grid += "<span class='badge alert-info' id='corr-low'>?</span>&nbsp;Low&nbsp;&nbsp;";
            grid += "<span class='badge alert-success' id='corr-info'>?</span>&nbsp;Info";
            grid += "</td></tr>";
            grid += "</tbody></table>";
            grid += "</div></div>";

            // Findings by category — plain sorted table
            grid += "<div class='panel panel-default'>";
            grid += "<div class='panel-heading'><strong>Findings by Category</strong> <small>(click a category to browse its data)</small></div>";
            grid += "<div class='panel-body' id='vbarsummary'><p class='text-muted'>Loading...</p></div>";
            grid += "</div>";

            grid += "</div>";

            $("#scansummary-content").remove();
            $("#scanlogs-content").remove();
            $("#loader").show();
            $("#btn-export").hide();
            $("#btn-download-logs").hide();
            $("#btn-refresh").hide();
            $("#btn-search").hide();
            $("#scanreminder").show();
            navTo("btn-status");

            $("#mainbody").append(grid);

            // Collect data and populate variables for use later
            dataloaders.push(
                function() {
                    sf.fetchData('${docroot}/scanstatus', {'id': instanceId}, function(data) {
                        scanName = data[0];
                        scanTarget = data[1];
                        scanStarted = data[2];
                        scanEnded = data[4];
                        scanStatus = data[5];
                        scanCorrelations = data[6];

                        $("#scan-target").html(scanTarget || '—');
                        $("#scan-started").html(scanStarted || '—');
                        $("#scan-ended").html(scanEnded || '—');
                        $("#corr-high").html(scanCorrelations['HIGH']);
                        $("#corr-medium").html(scanCorrelations['MEDIUM']);
                        $("#corr-low").html(scanCorrelations['LOW']);
                        $("#corr-info").html(scanCorrelations['INFO']);
                    });
                }
            );

            dataloaders.push(
                function() {
                    sf.fetchData('${docroot}/scanerrors', {'id': instanceId}, function(data) {
                        $("#errors").html(data.length);
                    });
                }
            );

            dataloaders.push(
                function() {
                    sf.fetchData('${docroot}/scansummary', {'id': instanceId, 'by': 'type'}, function(data) {
                        scanSummary = [];
                        totalCount = 0;
                        uniqueCount = 0;
                        for (i = 0; i < data.length; i++) {
                            scanSummary[i] = {};
                            scanSummary[i].scanId = instanceId;
                            scanSummary[i].id = data[i][0];
                            scanSummary[i].name = data[i][1];
                            scanSummary[i].total = data[i][3];
                            scanSummary[i].counter = data[i][4];
                            scanSummary[i].link = function(d) { return browseEventData(d.scanId, d.name, d.id, "full"); };
                            totalCount += data[i][3];
                            uniqueCount += data[i][4];
                            scanStatus = data[i][5];
                        }

                        for (x = 0; x < i; x++) {
                            scanSummary[x].pct = scanSummary[x].counter / uniqueCount;
                        }

                        $('#ucounter').html(uniqueCount);
                        $('#tcounter').html(totalCount);
                        $('#scanstatusbadge').html(scanStatus);

                        var statusy = "";
                        if (scanStatus == "FINISHED") {
                            statusy = "alert-success";
                        } else if (scanStatus.indexOf("ABORT") >= 0) {
                            statusy = "alert-warning";
                        } else if (scanStatus == "CREATED" || scanStatus == "RUNNING" || scanStatus == "STARTED" || scanStatus == "STARTING" || scanStatus == "INITIALIZING") {
                            statusy = "alert-info";
                        } else if (scanStatus.indexOf("FAILED") >= 0) {
                            statusy = "alert-danger";
                        } else {
                            statusy = "alert-info";
                        }
                        $('#scanstatusbadge').removeClass(["alert-info", "alert-warning", "alert-danger"]).addClass(statusy);
                        $('#status').html(scanStatus);
                        $("#vbarsummary").empty();
                        if (scanSummary.length == 0) {
                          $("#vbarsummary").append("<div class='alert alert-warning'><h4>No data.</h4>If the scan is still running this section will update shortly.</div>");
                        } else {
                          var sorted = scanSummary.slice().sort(function(a, b) { return b.total - a.total; });
                          var tbl = "<table class='table table-bordered table-striped table-condensed tablesorter'>";
                          tbl += "<thead><tr><th>Category</th><th>Total</th><th>Unique</th></tr></thead><tbody>";
                          for (var j = 0; j < sorted.length; j++) {
                            var sid = sorted[j].scanId;
                            var sname = sorted[j].name;
                            var stid = sorted[j].id;
                            var stotal = sorted[j].total;
                            var sunique = sorted[j].counter;
                            tbl += "<tr>";
                            tbl += "<td>";
                            tbl += "<a class='link' onClick='browseEventData(\"" + sid + "\",\"" + sname + "\",\"" + stid + "\",\"full\")'>" + sname + "</a>";
                            tbl += " <i class='glyphicon glyphicon-info-sign type-info-icon' title='What is this?' onclick='showTypeInfo(\"" + stid + "\",\"" + sname.replace(/"/g,'&quot;') + "\"," + stotal + "," + sunique + "); event.stopPropagation();'></i>";
                            tbl += "</td>";
                            tbl += "<td>" + stotal + "</td>";
                            tbl += "<td>" + sunique + "</td>";
                            tbl += "</tr>";
                          }
                          tbl += "</tbody></table>";
                          $("#vbarsummary").html(tbl);
                          $("#vbarsummary table").tablesorter();
                        }
                        $("#loader").fadeOut(500);
                    });
                }
            );

            loadersrunning = true;
            for (var i = 0; i < dataloaders.length; i++) {
                dataloaders[i]();
            }
            loadersrunning = false;
        }

        // Expand the correlation list to show the events associated
        function toggleCorrelation(instanceId, correlationId) {
