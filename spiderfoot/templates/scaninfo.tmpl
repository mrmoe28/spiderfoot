                fmt: function(d){ return d.length ? d[0][0] : '[domain]'; } },
            'DEFACED_INTERNET_NAME': { ph:'[from scan]',
                fmt: function(d){ return d.length ? d[0][0] : '[site]'; } }
        };

        function copyFixPrompt(btn) {
            var pre = btn.previousElementSibling;
            var text = pre.textContent;
            if (navigator.clipboard) {
                navigator.clipboard.writeText(text).then(function(){
                    btn.textContent = 'Copied!';
                    setTimeout(function(){ btn.textContent = 'Copy'; }, 1500);
                });
            } else {
                var ta = document.createElement('textarea');
                ta.value = text;
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
                btn.textContent = 'Copied!';
                setTimeout(function(){ btn.textContent = 'Copy'; }, 1500);
            }
        }

        function viewReport(instanceId) {
            $("#scansummary-content").remove();
            $("#scanlogs-content").remove();
            $("#loader").show();
            $("#btn-export").hide();
            $("#btn-download-logs").hide();
            $("#btn-refresh").show();
            $("#btn-search").hide();
            $("#scanreminder").hide();
            navTo("btn-report");
            refresh = function() { viewReport(instanceId); };

            $("#mainbody").append("<div id='scansummary-content'><p class='text-muted'>Building report…</p></div>");

            sf.fetchData('${docroot}/scansummary', {'id': instanceId, 'by': 'type'}, function(data) {
                if (!data || data.length === 0) {
                    $("#scansummary-content").html("<div class='alert alert-warning'><h4>No findings yet.</h4>The scan may still be running — refresh in a moment.</div>");
                    $("#loader").fadeOut(500);
                    return;
                }

                var groups = {high:[], medium:[], low:[], info:[]};
                for (var i = 0; i < data.length; i++) {
                    var typeId   = data[i][0];
                    var typeName = data[i][1];
                    var total    = data[i][3];
                    var unique   = data[i][4];
                    var risk     = reportRisk[typeId] || 'info';
                    groups[risk].push({typeId:typeId, typeName:typeName, total:total, unique:unique});
                }

                var html = "<div id='scansummary-content'>";
                html += "<h3 style='margin-top:0'>Plain-English Report</h3>";
                html += "<p class='text-muted'>Every finding is explained below in plain language, sorted by risk. Click a category name to browse the raw data.</p>";

                var order = ['high','medium','low','info'];
                var headings = {high:'<span style="color:#c0392b">High Risk — Act Now</span>',
                                medium:'<span style="color:#e67e22">Medium Risk — Review Soon</span>',
                                low:'<span style="color:#2980b9">Low / Informational</span>',
                                info:'<span style="color:#7f8c8d">Background Info</span>'};

                var needsData = []; // items we need to fetch real data for
                var fixedKey = function(tid) { return 'bsfix:' + instanceId + ':' + tid; };
                var isFixed = function(tid) { return localStorage.getItem(fixedKey(tid)) === '1'; };

                for (var r = 0; r < order.length; r++) {
                    var risk = order[r];
                    if (groups[risk].length === 0) continue;
                    html += "<h4 style='border-bottom:2px solid #eee;padding-bottom:6px;margin-top:28px'>" + headings[risk] + "</h4>";
                    html += "<div class='list-group'>";
                    for (var j = 0; j < groups[risk].length; j++) {
                        var item = groups[risk][j];
                        var desc = eventTypeHelp[item.typeId] || 'Data collected during the scan.';
                        var fix  = eventTypeFix[item.typeId] || null;
                        var preId = 'fix-pre-' + item.typeId;
                        var cardId = 'rcard-' + item.typeId;
                        var fixed = isFixed(item.typeId);
                        var cardStyle = fixed ? 'margin-bottom:10px;opacity:0.45;' : 'margin-bottom:10px;';
                        html += "<div id='" + cardId + "' class='list-group-item' style='" + cardStyle + "'>";
                        html += "<div style='display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:6px'>";
                        html += "<h5 style='margin:0;flex:1'>";
                        html += "<a class='link' onClick='browseEventData(\"" + instanceId + "\",\"" + item.typeName.replace(/"/g,'&quot;') + "\",\"" + item.typeId + "\",\"full\")'>" + item.typeName + "</a>";
                        html += "&nbsp;";
                        if (fixed) {
                            html += "<span class='label' style='background:#27ae60'>FIXED</span>";
                        } else {
                            html += riskLabel[risk];
                        }
                        html += "</h5>";
                        html += "<div style='display:flex;align-items:center;gap:10px'>";
                        html += "<span class='text-muted' style='font-size:12px;white-space:nowrap'>" + item.unique + " unique / " + item.total + " total</span>";
                        html += "<label style='margin:0;display:flex;align-items:center;gap:5px;cursor:pointer;font-size:12px;white-space:nowrap'>";
                        html += "<input type='checkbox' onchange='toggleFixed(\"" + instanceId + "\",\"" + item.typeId + "\",\"" + cardId + "\",\"" + risk + "\",this)'" + (fixed ? ' checked' : '') + " style='cursor:pointer'>";
                        html += "Mark fixed</label>";
                        html += "</div>";
                        html += "</div>";
                        html += "<p style='margin:8px 0 4px 0;color:#444'>" + desc + "</p>";
                        if (fix) {
                            html += "<div style='margin-top:8px'>";
                            html += "<strong style='font-size:12px'>Claude Code Fix Prompt:</strong>";
                            html += "<div style='position:relative;margin-top:4px'>";
                            html += "<pre id='" + preId + "' style='font-size:11px;background:#f8f8f8;border:1px solid #ddd;padding:8px;white-space:pre-wrap;word-break:break-word;max-height:140px;overflow:auto'>" + fix + "</pre>";
                            html += "<button class='btn btn-xs btn-default' style='position:absolute;top:4px;right:4px' onclick='copyFixPrompt(this)'>Copy</button>";
                            html += "</div></div>";
                            if (fixDataConfig[item.typeId]) {
                                needsData.push({typeId: item.typeId, preId: preId, cfg: fixDataConfig[item.typeId]});
                            }
                        }
                        html += "</div>";
                    }
                    html += "</div>";
                }
                html += "</div>";

                $("#scansummary-content").replaceWith(html);
                $("#loader").fadeOut(500);

                // Now fetch real scan data for each type and substitute into the prompts
                for (var k = 0; k < needsData.length; k++) {
                    (function(entry) {
                        sf.fetchData('${docroot}/scaneventresultsunique', {'id': instanceId, 'eventType': entry.typeId, 'filterfp': null}, function(rows) {
                            if (!rows || rows.length === 0) return;
                            var preEl = document.getElementById(entry.preId);
                            if (!preEl) return;
                            var realValue = entry.cfg.fmt(rows);
                            preEl.textContent = preEl.textContent.replace(entry.cfg.ph, realValue);
                        });
                    })(needsData[k]);
                }
            });
        }

        function toggleFixed(instanceId, typeId, cardId, risk, cb) {
            var key = 'bsfix:' + instanceId + ':' + typeId;
            var card = document.getElementById(cardId);
            var riskLabel = {'high':'<span class="label label-danger">HIGH RISK</span>',
                             'medium':'<span class="label label-warning">MEDIUM</span>',
                             'low':'<span class="label label-info">LOW</span>',
                             'info':'<span class="label label-default">INFO</span>'};
            if (cb.checked) {
                localStorage.setItem(key, '1');
                card.style.opacity = '0.45';
                var badge = card.querySelector('h5 span.label');
                if (badge) badge.outerHTML = '<span class="label" style="background:#27ae60">FIXED</span>';
            } else {
                localStorage.removeItem(key);
                card.style.opacity = '';
                var badge = card.querySelector('h5 span.label');
                if (badge) badge.outerHTML = riskLabel[risk] || '';
            }
        }
        // ── End Report tab ───────────────────────────────────────────────────

        if ("${status}" == "CREATED" || "${status}" == "RUNNING" || "${status}" == "STARTING" || "${status}" == "STARTED" || "${status}" == "UNKNOWN" || "${status}" == "INITIALIZING") {
            scanSummaryView("${id}");
        } else {
            browseEventList("${id}");
        }

        var refreshSummaryInterval;

        refreshSummary = function() {
            var status = document.getElementById("scanstatusbadge").innerHTML;

            if (status == "ERROR-FAILED" || status == "FINISHED" || status == "ABORTED") {
                sf.log("Scan is " + status);
                clearInterval(refreshSummaryInterval);
                return;
            }

            sf.log("Scan is " + status + ". Refreshing scan summary ...");

            for (var i = 0; i < dataloaders.length; i++) {
                if (!loadersrunning) {
                    loadersrunning = true;
                    dataloaders[i]();
                    loadersrunning = false;
                }
            }
        }

        refreshSummaryInterval = setInterval(refreshSummary, 5000);

    </script>
<iframe class="hidden" id='exportframe'></iframe>
<%include file="FOOTER.tmpl"/>
